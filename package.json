{
  "name": "parcel-pilot-mcp",
  "version": "0.1.0",
  "description": "Local-first MCP server that uses personal browser sessions to query Taobao and JD package progress.",
  "type": "module",
  "bin": {
    "parcel-pilot-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "call-tool": "tsx src/cli/call-tool.ts",
    "dev": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "postinstall": "playwright install chromium"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    ".env.example"
  ],
  "keywords": [
    "mcp",
    "taobao",
    "jd",
    "packages",
    "playwright"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cheerio": "^1.2.0",
    "playwright": "^1.44.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "ip-address": "10.2.0"
  }
}
